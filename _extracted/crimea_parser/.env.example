# Скопируй в .env и заполни при необходимости.
# По умолчанию парсер пишет только в CSV (output/), БД отключена.

# DSN PostgreSQL (опционально). Пример:
# PG_DSN=postgresql://user:pass@127.0.0.1:5432/crimea
PG_DSN=

# Headless-режим Chromium. По умолчанию false (запуск через xvfb-run).
# Установи 1/true чтобы форсировать headless локально.
HEADLESS=

# Telegram-отчёт после прогона (опционально).
# Получи токен у @BotFather и добавь бота в группу/канал, узнай ID через @userinfobot.
TG_BOT_TOKEN=
TG_CHAT_ID=

# Google Drive: upload reports after each parse run.
# Folder ID is the last part of: drive.google.com/drive/folders/<ID>
# Share the folder with the service account email (Editor role).
# Enable Drive API in Google Cloud Console for the same project.
GDRIVE_FOLDER_ID=
# Path to OAuth2 token.json generated by setup_gdrive_auth.py (run once locally).
GDRIVE_TOKEN=/home/crimea_parser/token.json

# Установи 1 чтобы обогащать только последний result_*.csv (устаревший режим).
# По умолчанию обогащается master_all.csv со всеми накопленными данными.
ENRICH_LATEST=
