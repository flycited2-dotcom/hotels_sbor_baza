# Скопируй в .env и заполни при необходимости.
# По умолчанию парсер пишет только в CSV (output/), БД отключена.

# DSN PostgreSQL (опционально). Пример:
# PG_DSN=postgresql://user:pass@127.0.0.1:5432/crimea
PG_DSN=

# Headless-режим Chromium. По умолчанию false (запуск через xvfb-run).
# Установи 1/true чтобы форсировать headless локально.
HEADLESS=

# Telegram-отчёт после прогона (опционально).
# Получи токен у @BotFather и добавь бота в группу/канал, узнай ID через @userinfobot.
TG_BOT_TOKEN=
TG_CHAT_ID=
