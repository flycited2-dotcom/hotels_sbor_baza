# Telegram Bot API token (получить у @BotFather)
BOT_TOKEN=

# Список chat_id админов через запятую (узнать через @userinfobot)
# Только эти chat_id могут управлять парсером
ADMIN_CHAT_IDS=

# Где живёт парсер на сервере (для поиска CSV в output/)
PARSER_DIR=/home/crimea_parser

# Имена systemd-юнитов (можно менять, но обычно дефолты)
PARSER_UNIT=crimea_parser.service
PARSER_TIMER=crimea_parser.timer
EMAILS_UNIT=crimea_email_finder.service

# Уровень логирования
LOG_LEVEL=INFO
